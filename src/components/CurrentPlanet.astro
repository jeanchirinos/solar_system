---
import { Image } from 'astro:assets'
import type { Planet } from '@/types/Planet'
import { ENV } from '@/constants/env'

interface Props {
  planet: Planet
}

const { planet } = Astro.props
---

<Image
  slot='prev'
  loading='eager'
  src={`${ENV.IMAGES_URL}${planet.webp!}`}
  alt={planet.name}
  inferSize
  class='max-sm -order-1 max-h-full w-auto'
  {...Astro.props}
/>
